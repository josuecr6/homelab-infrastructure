global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets:
          - "localhost:{{ prometheus_port }}"

{% for job in prometheus_targets %}
  - job_name: "{{ job.job_name }}"
    static_configs:
      - targets:
{% for target in job.targets %}
          - "{{ target }}"
{% endfor %}
{% endfor %}
